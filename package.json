{
  "name": "iterationlayer",
  "version" : "2.0.4",
  "description": "Official TypeScript/Node.js SDK for the Iteration Layer API",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "format": "biome format --write src",
    "format:check": "biome format src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "iteration-layer",
    "api",
    "sdk",
    "document-extraction",
    "image-generation",
    "image-transformation",
    "document-generation"
  ],
  "author": "Iteration Layer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iterationlayer/sdk-node"
  },
  "homepage": "https://iterationlayer.com/docs",
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "tsup": "8.5.0",
    "typescript": "5.8.3",
    "vitest": "4.0.18"
  }
}
